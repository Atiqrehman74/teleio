{
  "name": "teleio-tourism",
  "version": "1.0.0",
  "description": "Teleio Tourism — Travel & Visa Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "export": "next build && next export",
    "cap:init": "npx @capacitor/cli@latest init teleio \"Teleio Tourism\" --web-dir=out",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "stripe": "^14.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/core": "^5.0.0"
  }
}
